# Required: Career Caddy API connection.
# To self-host against your own Career Caddy instance, change all three
# of these to point at your domain — no code changes required.
CC_API_BASE_URL=https://api.careercaddy.online        # REST writes
CC_MCP_URL=https://mcp.careercaddy.online/mcp         # MCP reads
CC_API_TOKEN=jh_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: At least one LLM provider
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Per-agent model overrides (defaults to openai:gpt-4o-mini)
# CADDY_MODEL=openai:gpt-4o-mini
# JOB_EXTRACTOR_MODEL=anthropic:claude-haiku-4-5-20251001
# EMAIL_CLASSIFIER_MODEL=openai:gpt-4o-mini
# JOB_POST_REFINER_MODEL=openai:gpt-4o-mini
# FOLLOWUP_PROCESSOR_MODEL=openai:gpt-4o-mini
# BROWSER_SCRAPER_MODEL=openai:gpt-4o-mini
# CADDY_DEFAULT_MODEL=openai:gpt-4o-mini

# Optional: Email backend selection for caddy-inbox
# CADDY_EMAIL_BACKEND=notmuch   # or 'imap' (IMAP not yet implemented; see notes.org:426)

# Optional: notmuch backend (requires notmuch CLI installed)
# NOTMUCH_MAILDIR=~/.mail

# Optional: IMAP backend (not yet wired)
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USERNAME=you@example.com
# IMAP_PASSWORD=app-password-goes-here
# IMAP_DEFAULT_FOLDER=INBOX

# Optional: Observability
# LOGFIRE_TOKEN=
# LOGFIRE_READ_TOKEN=          # needed for `mcp__logfire__arbitrary_query` against the cc_auto write project

# Optional: Mongo observability (Phase A — triage_runs / triage_emails / skipped_duplicates)
# `docker compose up -d mongo` brings the sidecar up against the default URI.
# MONGODB_URI=mongodb://localhost:27017/cc_auto

# Optional: Catchall forward poller (caddy-catchall) — known-good auto-scrape.
# Both default OFF, so production behavior is unchanged until you opt in.
# AUTO_SCRAPE: when a forwarded JobPost lands on a known-good (Tier-0)
#   domain, create a `hold` Scrape so the scrape runner pulls it.
# ATTENDED: additionally mark that Scrape `attended=True` so ONLY an
#   attended runner (`make runner ARGS="--attended"`, warm cookies/login)
#   claims it. If no attended runner is running, the scrape sits in `hold`
#   indefinitely — that is why this defaults OFF.
# CADDY_FORWARD_AUTO_SCRAPE_KNOWN_GOOD=0
# CADDY_FORWARD_ATTENDED_KNOWN_GOOD=0

# Optional: Filesystem anchors
# CADDY_HOME=                  # default: directory containing pyproject.toml
# CADDY_LOG_DIR=               # default: $CADDY_HOME/var/logs/
# CADDY_FILE_LOG=1             # set to 0 to disable the rotating file log (MCP stdio servers)

